#!/usr/bin/env bash
# Paste the path of the most recent screenshot into the active tmux pane.
# Part of bauble — ambient session UX for Claude Code
#
# Config (bauble.conf or ~/.config/bauble.conf):
#   BAUBLE_SCREENSHOT_DIR        — directory to scan (default: macOS screencapture location or ~/Desktop)
#   BAUBLE_SCREENSHOT_BY_NAME    — 1 to match by filename pattern, 0 for most-recent-file (default: 1)
#   BAUBLE_SCREENSHOT_TIME_FMT   — Python strftime format for the timestamp portion (default: "%Y-%m-%d at %-I.%M.%S %p")
#
# Default filename pattern: "Screenshot 2026-02-26 at 6.58.14 PM.png"

# Resolve through symlinks to find the actual script directory
SOURCE="${BASH_SOURCE[0]}"
while [ -L "$SOURCE" ]; do
  DIR="$(cd "$(dirname "$SOURCE")" && pwd)"
  SOURCE="$(readlink "$SOURCE")"
  [[ "$SOURCE" != /* ]] && SOURCE="$DIR/$SOURCE"
done
SCRIPT_DIR="$(cd "$(dirname "$SOURCE")" && pwd)"

# Load config
CONF="$(dirname "$SCRIPT_DIR")/config/bauble.conf"
[ -f "$CONF" ] && source "$CONF"

# Defaults
if [ -z "$BAUBLE_SCREENSHOT_DIR" ]; then
  if [ "$(uname -s)" = "Darwin" ]; then
    BAUBLE_SCREENSHOT_DIR=$(defaults read com.apple.screencapture location 2>/dev/null || echo "$HOME/Desktop")
  else
    if [ -f "$HOME/.config/user-dirs.dirs" ]; then
      XDG_PICTURES_DIR=$(grep '^XDG_PICTURES_DIR=' "$HOME/.config/user-dirs.dirs" 2>/dev/null \
        | head -1 | cut -d= -f2- | tr -d '"' | sed "s|\\\$HOME|$HOME|g")
    fi
    BAUBLE_SCREENSHOT_DIR="${XDG_PICTURES_DIR:-$HOME/Pictures}"
    [ ! -d "$BAUBLE_SCREENSHOT_DIR" ] && BAUBLE_SCREENSHOT_DIR="$HOME/Desktop"
  fi
fi
BAUBLE_SCREENSHOT_BY_NAME="${BAUBLE_SCREENSHOT_BY_NAME:-1}"
BAUBLE_SCREENSHOT_TIME_FMT="${BAUBLE_SCREENSHOT_TIME_FMT:-%Y-%m-%d at %-I.%M.%S %p}"

# Convert a Python strftime format string to an extended regex pattern.
# Handles common tokens; unrecognized %-sequences pass through as literals.
strftime_to_regex() {
  local fmt="$1"
  local regex=""
  local i=0
  local len=${#fmt}

  while [ $i -lt $len ]; do
    local ch="${fmt:$i:1}"
    if [ "$ch" = "%" ] && [ $((i + 1)) -lt $len ]; then
      local next="${fmt:$((i+1)):1}"
      # Handle %-X (no-padding) variants
      if [ "$next" = "-" ] && [ $((i + 2)) -lt $len ]; then
        local after="${fmt:$((i+2)):1}"
        case "$after" in
          d|e|m) regex+="[0-9]{1,2}"; i=$((i + 3)); continue ;;
          I|H)   regex+="[0-9]{1,2}"; i=$((i + 3)); continue ;;
          M|S)   regex+="[0-9]{1,2}"; i=$((i + 3)); continue ;;
          *)     regex+="%"; i=$((i + 1)); continue ;;
        esac
      fi
      case "$next" in
        Y) regex+="[0-9]{4}" ;;
        m) regex+="[0-9]{2}" ;;
        d) regex+="[0-9]{2}" ;;
        H) regex+="[0-9]{2}" ;;
        I) regex+="[0-9]{2}" ;;
        M) regex+="[0-9]{2}" ;;
        S) regex+="[0-9]{2}" ;;
        p) regex+="(AM|PM)" ;;
        e) regex+="[0-9 ]{2}" ;;
        %) regex+="%" ;;
        *) regex+="%${next}" ;;
      esac
      i=$((i + 2))
    else
      # Escape regex-special characters
      case "$ch" in
        '.'|'['|']'|'('|')'|'{'|'}'|'+'|'*'|'?'|'^'|'$'|'|'|'\\')
          regex+="\\${ch}" ;;
        *) regex+="$ch" ;;
      esac
      i=$((i + 1))
    fi
  done
  echo "$regex"
}

find_by_name() {
  local time_regex
  time_regex=$(strftime_to_regex "$BAUBLE_SCREENSHOT_TIME_FMT")
  local pattern="^Screenshot ${time_regex}\\.png$"

  # Find matching files, sort by name descending (lexicographic = chronological for these formats)
  local found
  found=$(find "$BAUBLE_SCREENSHOT_DIR" -maxdepth 1 -type f -name "Screenshot *.png" 2>/dev/null \
    | while IFS= read -r f; do
        basename=$(basename "$f")
        if echo "$basename" | grep -qE "$pattern"; then
          echo "$f"
        fi
      done \
    | sort -r \
    | head -1)
  echo "$found"
}

find_by_recency() {
  # Most recently modified file in the directory (any type)
  ls -t "$BAUBLE_SCREENSHOT_DIR"/* 2>/dev/null | head -1
}

# Find the screenshot
if [ "$BAUBLE_SCREENSHOT_BY_NAME" = "1" ]; then
  latest=$(find_by_name)
  # Fall back to recency if no name match
  [ -z "$latest" ] && latest=$(find_by_recency)
else
  latest=$(find_by_recency)
fi

if [ -z "$latest" ]; then
  tmux display-message "No screenshot found in $BAUBLE_SCREENSHOT_DIR"
  exit 0
fi

tmux send-keys -l -- "$latest"
