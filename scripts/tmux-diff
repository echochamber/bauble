#!/usr/bin/env bash
# tmux-diff: scan current pane for edited files, show per-file diffs
# Part of bauble — ambient session UX for Claude Code
#
# Bound to tmux prefix+g, d. Scans the pane scrollback for:
#   1. Claude Code edit markers (Write/Update/Edit) -> session diffs
#   2. File paths with git changes -> git diffs
# Shows a filterable popup to pick which file to view.
#
# Modes:
#   (default)      Scan pane -> launch popup with gum filter, or fall back to display-menu
#   --popup <list> Runs inside the tmux popup: read pre-scanned list -> gum filter -> dispatch
#   --view-git     Open git diff for a file in a split
#   --view-session Open session diff from temp file in a split

set -euo pipefail

# Resolve through symlinks to find the actual script directory
SOURCE="${BASH_SOURCE[0]}"
while [ -L "$SOURCE" ]; do
  DIR="$(cd "$(dirname "$SOURCE")" && pwd)"
  SOURCE="$(readlink "$SOURCE")"
  [[ "$SOURCE" != /* ]] && SOURCE="$DIR/$SOURCE"
done
SCRIPT_DIR="$(cd "$(dirname "$SOURCE")" && pwd)"

SELF="$HOME/.claude/scripts/tmux-diff"
BAUBLE_TMP="/tmp/bauble-${UID}"
mkdir -p -m 700 "$BAUBLE_TMP" 2>/dev/null

# Load config
CONF="$(dirname "$SCRIPT_DIR")/config/bauble.conf"
[ -f "$CONF" ] && source "$CONF"
BAUBLE_MAX_MENU_ITEMS="${BAUBLE_MAX_MENU_ITEMS:-8}"
BAUBLE_SCROLLBACK_LINES="${BAUBLE_SCROLLBACK_LINES:-5000}"
BAUBLE_SPLIT_WIDTH="${BAUBLE_SPLIT_WIDTH:-100}"

# Escape single quotes for tmux split-window arguments
sq() { local s="$1"; echo "${s//\'/\'\\\'\'}"; }

# Compute adaptive split: horizontal if viewer takes <50% of pane width, else vertical
_PANE_W=$(tmux display-message -p '#{pane_width}')
_SPLIT_W="$BAUBLE_SPLIT_WIDTH"
if [ $((_PANE_W / 2)) -gt "$_SPLIT_W" ]; then
  SPLIT="split-window -h -l $_SPLIT_W"
else
  SPLIT="split-window -v -l 60%"
fi

# Detect differ (prefer delta, fall back to less)
if command -v delta &>/dev/null; then
  PAGER="delta --paging=always"
else
  PAGER="less -R"
fi

# ── --view-git handler: open git diff in split ──
if [[ "${1:-}" == "--view-git" ]]; then
  filepath="${2:-}"
  git_root="${3:-}"
  if [ -n "$filepath" ] && [ -n "$git_root" ]; then
    rel="${filepath#"$git_root"/}"
    tmux $SPLIT "cd '$(sq "$git_root")'; git diff HEAD -- '$(sq "$rel")' | $PAGER"
  fi
  exit 0
fi

# ── --view-session handler: open session diff from temp file in split ──
if [[ "${1:-}" == "--view-session" ]]; then
  tmpfile="${2:-}"
  if [ -n "$tmpfile" ] && [ -f "$tmpfile" ]; then
    tmux $SPLIT "$PAGER '$(sq "$tmpfile")'; rm -f '$(sq "$tmpfile")'"
  fi
  exit 0
fi

# ── --popup mode: gum filter inside the tmux popup ──
if [[ "${1:-}" == "--popup" ]]; then
  tmplist="${2:-}"

  # Ensure PATH includes common tool locations
  for p in /opt/homebrew/bin /usr/local/bin "$HOME/.claude/scripts"; do
    [[ -d "$p" ]] && [[ ":$PATH:" != *":$p:"* ]] && PATH="$p:$PATH"
  done

  if [ -z "$tmplist" ] || [ ! -f "$tmplist" ]; then
    echo "No diffs to display."
    sleep 1
    exit 0
  fi

  DELIM="┊"
  display_lines=()
  while IFS=$'\t' read -r type filepath extra; do
    [ -z "$filepath" ] && continue
    name=$(basename "$filepath")
    parent=$(basename "$(dirname "$filepath")")
    tag=""
    [ "$type" = "session" ] && tag=" (session)"
    display_lines+=("${parent}/${name}${tag} ${DELIM}${type}${DELIM}${filepath}${DELIM}${extra}")
  done < "$tmplist"
  rm -f "$tmplist" 2>/dev/null

  if [ ${#display_lines[@]} -eq 0 ]; then
    echo "No diffs found."
    sleep 1
    exit 0
  fi

  selected=$(printf '%s\n' "${display_lines[@]}" | gum filter \
    --fuzzy \
    --header "View diff  (type to filter)" \
    --header.foreground 99 \
    --placeholder "Filter..." \
    --prompt "> " \
    --prompt.foreground 99 \
    --indicator.foreground 99 \
    --select-if-one \
    --strict \
    --height 16 \
    --width 0) || exit 0

  # Extract metadata: "label ┊type┊filepath┊extra"
  extra="${selected##*${DELIM}}"
  rest="${selected%${DELIM}${extra}}"
  filepath="${rest##*${DELIM}}"
  rest="${rest%${DELIM}${filepath}}"
  type="${rest##*${DELIM}}"

  if [ "$type" = "git" ]; then
    exec "$SELF" --view-git "$filepath" "$extra"
  elif [ "$type" = "session" ]; then
    exec "$SELF" --view-session "$extra"
  fi
  exit 0
fi

# ── Default mode: scan pane and present results ──

# Build capture-pane args
if [ "$BAUBLE_SCROLLBACK_LINES" = "-" ]; then
  CAPTURE_START="-"
else
  CAPTURE_START="-${BAUBLE_SCROLLBACK_LINES}"
fi

# Capture the full scrollback once (used for all scanning)
SCROLLBACK=$(tmux capture-pane -p -S "$CAPTURE_START")

# --- Extract session diff from $SCROLLBACK for a given file ---
extract_session_diff() {
  local filepath="$1"
  local tilde_path
  tilde_path=$(echo "$filepath" | sed "s|^$HOME|~|")

  local marker_line
  marker_line=$(
    echo "$SCROLLBACK" \
    | grep -nE "⏺ (Write|Update|Edit)\($tilde_path\)|⏺ (Write|Update|Edit)\($filepath\)" \
    | tail -1 \
    | cut -d: -f1
  )
  [ -z "$marker_line" ] && return 1

  local content
  content=$(echo "$SCROLLBACK" | tail -n +"$marker_line" | awk '
    NR == 1 { print; next }
    /^⏺/ { exit }
    /^[A-Z]/ && NR > 4 { exit }
    /^$/ && blank++ > 2 { exit }
    /^[^ \t]/ && !/^[0-9 ]*[-+]/ && NR > 2 { exit }
    { blank=0; print }
  ')

  local line_count
  line_count=$(echo "$content" | wc -l)
  [ "$line_count" -le 1 ] && return 1

  echo "Session diff: $(basename "$filepath")"
  echo "File: $filepath"
  echo ""
  echo "$content"
}

# --- Find files from Claude Code edit markers ---
edit_paths=$(
  echo "$SCROLLBACK" \
  | grep -oE '⏺ (Write|Update|Edit)\([^)]+\)' \
  | sed 's/^⏺ [A-Za-z]*(//' \
  | sed 's/)$//' \
  | sed "s|^~|$HOME|" \
  | tac \
  | awk '!seen[$0]++'
)

# --- Find file paths with git changes ---
raw_paths=$(
  echo "$SCROLLBACK" \
  | grep -oE 'file:///[^ "'"'"']+|/Users/[^ "'"'"']+|/tmp/[^ "'"'"']+|~/[^ "'"'"']+' \
  | sed 's|^file://||' \
  | sed "s|^~|$HOME|" \
  | sed 's/[.,;:)]*$//' \
  | tac \
  | awk '!seen[$0]++'
)

# Merge: edit markers first (higher signal), then raw paths
all_paths=$(printf '%s\n%s' "$edit_paths" "$raw_paths" | awk '!/^$/ && !seen[$0]++')

# Classify each file: git diff, session diff, or skip
matched=()
declare -A match_type  # "git" or "session"
declare -A match_root
declare -A match_tmpfile  # pre-extracted session diff temp files
declare -A seen_files

while IFS= read -r p; do
  [ -z "$p" ] && continue
  [ -f "$p" ] || continue
  [ -n "${seen_files[$p]+x}" ] && continue
  # Skip temp/scratch files
  case "$p" in /tmp/*) continue ;; esac
  seen_files[$p]=1

  fdir=$(dirname "$p")
  git_root=$(cd "$fdir" 2>/dev/null && git rev-parse --show-toplevel 2>/dev/null)

  # Check for git changes first (highest fidelity)
  if [ -n "$git_root" ]; then
    rel="${p#"$git_root"/}"
    if ! (cd "$git_root" && git diff --quiet -- "$rel" 2>/dev/null && git diff --cached --quiet -- "$rel" 2>/dev/null); then
      matched+=("$p")
      match_type[$p]="git"
      match_root[$p]="$git_root"
      [ ${#matched[@]} -ge "$BAUBLE_MAX_MENU_ITEMS" ] && break
      continue
    fi
  fi

  # Check if Claude edited it this session — pre-extract the diff now
  tmpfile=$(mktemp $BAUBLE_TMP/sdiff-XXXXXX)
  if extract_session_diff "$p" > "$tmpfile" 2>/dev/null; then
    matched+=("$p")
    match_type[$p]="session"
    match_tmpfile[$p]="$tmpfile"
    [ ${#matched[@]} -ge "$BAUBLE_MAX_MENU_ITEMS" ] && break
  else
    rm -f "$tmpfile"
  fi
done <<< "$all_paths"

# Fallback: all changed files in CWD's repo
if [ ${#matched[@]} -eq 0 ]; then
  cwd_root=$(git rev-parse --show-toplevel 2>/dev/null)
  if [ -n "$cwd_root" ]; then
    changed=$( { git -C "$cwd_root" diff --name-only 2>/dev/null; git -C "$cwd_root" diff --cached --name-only 2>/dev/null; } | sort -u )
    while IFS= read -r rel; do
      [ -n "$rel" ] || continue
      p="$cwd_root/$rel"
      matched+=("$p")
      match_type[$p]="git"
      match_root[$p]="$cwd_root"
      [ ${#matched[@]} -ge "$BAUBLE_MAX_MENU_ITEMS" ] && break
    done <<< "$changed"
  fi
fi

if [ ${#matched[@]} -eq 0 ]; then
  rm -f "$BAUBLE_TMP"/sdiff-* 2>/dev/null
  tmux display-message "No changed files found"
  exit 0
fi

# --- Open a single match directly ---
if [ ${#matched[@]} -eq 1 ]; then
  p="${matched[0]}"
  if [ "${match_type[$p]}" = "git" ]; then
    root="${match_root[$p]}"
    rel="${p#"$root"/}"
    tmux $SPLIT "cd '$(sq "$root")'; git diff HEAD -- '$(sq "$rel")' | $PAGER"
  else
    tf="${match_tmpfile[$p]}"
    tmux $SPLIT "$PAGER '$(sq "$tf")'; rm -f '$(sq "$tf")'"
  fi
  exit 0
fi

# --- Multiple matches: launch popup or fall back to display-menu ---

# Try Textual UI first (fastest, best UX)
if command -v bauble-ui &>/dev/null; then
  tmux display-popup -w 80 -h 20 -E "bauble-ui diff"
  exit 0
fi

if command -v gum &>/dev/null; then
  # Write match info to a temp file so the popup can read it
  # Format: type<TAB>filepath<TAB>git_root_or_tmpfile
  tmplist=$(mktemp $BAUBLE_TMP/difflist-XXXXXX)
  for p in "${matched[@]}"; do
    type="${match_type[$p]}"
    if [ "$type" = "git" ]; then
      printf 'git\t%s\t%s\n' "$p" "${match_root[$p]}"
    else
      printf 'session\t%s\t%s\n' "$p" "${match_tmpfile[$p]}"
    fi
  done > "$tmplist"

  tmux display-popup -w 80 -h 20 -E "bash -l '${SELF}' --popup '$tmplist'"
  rm -f "$tmplist" 2>/dev/null
  exit 0
fi

# ── Display-menu fallback (no gum available) ──
args=()
for p in "${matched[@]}"; do
  name=$(basename "$p")
  parent=$(basename "$(dirname "$p")")
  type="${match_type[$p]}"

  if [ "$type" = "git" ]; then
    root="${match_root[$p]}"
    rel="${p#"$root"/}"
    args+=("$parent/$name" "" "$SPLIT \"cd '$(sq "$root")'; git diff HEAD -- '$(sq "$rel")' | $PAGER\"")
  else
    tf="${match_tmpfile[$p]}"
    args+=("$parent/$name (session)" "" "$SPLIT \"$PAGER '$(sq "$tf")'; rm -f '$(sq "$tf")'\"")
  fi
done
tmux display-menu -T "View diff" "${args[@]}"
